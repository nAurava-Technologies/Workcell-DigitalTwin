def Scope "Materials"
{
    def Material "Cod_Gray"
    {
        token outputs:displacement (
            displayGroup = "Outputs"
            doc = '''Represents the universal "displacement" output terminal of a 
        material.'''
        )
        prepend token outputs:mdl:displacement.connect = </Materials/Cod_Gray/Shader.outputs:out>
        prepend token outputs:mdl:surface.connect = </Materials/Cod_Gray/Shader.outputs:out>
        prepend token outputs:mdl:volume.connect = </Materials/Cod_Gray/Shader.outputs:out>
        token outputs:surface (
            displayGroup = "Outputs"
            doc = '''Represents the universal "surface" output terminal of a
        material.'''
        )
        token outputs:volume (
            displayGroup = "Outputs"
            doc = '''Represents the universal "volume" output terminal of a
        material.'''
        )

        def Shader "Shader" (
            apiSchemas = ["NodeDefAPI"]
        )
        {
            token info:implementationSource = "sourceAsset"
            asset info:mdl:sourceAsset = @OmniPBR.mdl@
            token info:mdl:sourceAsset:subIdentifier = "OmniPBR"
            color3f inputs:diffuse_color_constant = (0.039215688, 0.039215688, 0.039215688)
            color3f inputs:emissive_color = (0, 0, 0)
            float inputs:emissive_intensity = 0
            bool inputs:enable_emission = 0
            float inputs:metallic_constant = 0
            float inputs:reflection_roughness_constant = 0.5
            token outputs:out
        }
    }

